{
  "Auth": {
    "Mode": "ApiKey",
    "HeaderName": "X-Api-Key",
    "ApiKey": ""
  },
  "Nexo": {
    "Database": {
      "SqlServer": "localhost",
      "DatabaseName": "MyDb",
      "UseWindowsAuth": true,
      "SqlUser": "sql_user_here",
      "SqlPassword": "sql_password_here"
    },
    "SystemLogin": {
      "NexoUser": "system_user_here",
      "NexoPassword": "system_password_here"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "SubiektNexoConnector.Api"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
